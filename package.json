{
  "name": "github-better-csv-diff",
  "version": "0.2.1",
  "description": "Browser extension that renders CSV file diffs as side-by-side tables on GitHub",
  "author": "letconst",
  "license": "MIT",
  "homepage": "https://github.com/letconst/github-better-csv-diff",
  "repository": {
    "type": "git",
    "url": "https://github.com/letconst/github-better-csv-diff.git"
  },
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@types/papaparse": "^5.5.2",
    "@wxt-dev/auto-icons": "^1.1.1",
    "typescript": "^5.9.3",
    "wxt": "^0.20.0"
  },
  "private": true,
  "dependencies": {
    "diff": "^8.0.3",
    "papaparse": "^5.5.3"
  }
}
